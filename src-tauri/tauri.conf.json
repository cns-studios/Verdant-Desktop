{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Verdant Desktop",
  "version": "2.2.3",
  "identifier": "com.cns-studios.verdant",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Verdant Mail",
        "width": 1200,
        "height": 900,
        "resizable": true,
        "decorations": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https://logo.clearbit.com https://www.google.com; font-src 'self' https://fonts.googleapis.com; style-src 'self' https://fonts.googleapis.com; script-src 'self'; connect-src 'self' https://; frame-src 'self';"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
